{
  "timeZone": "America/Los_Angeles",
  "dependencies": {
    "enabledAdvancedServices": [
      {
        "userSymbol": "Calendar",
        "version": "v3",
        "serviceId": "calendar"
      }
    ]
  },
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "oauthScopes": [
    "https://www.googleapis.com/auth/calendar.addons.execute",
    "https://www.googleapis.com/auth/calendar.addons.current.event.read",
    "https://www.googleapis.com/auth/calendar.events.readonly"
  ],
  "addOns": {
    "common": {
      "name": "Agentforce Briefs",
      "logoUrl": "https://github.com/MHolenstein/Agentforce-Briefs/blob/main/agentforce-icon.png?raw=true",
      "homepageTrigger": {
        "runFunction": "buildHomepageCard"
      }
    },
    "calendar": {
      "homepageTrigger": {
        "runFunction": "buildHomepageCard"
      },
      "eventOpenTrigger": {
        "runFunction": "buildEventBriefCard"
      },
      "currentEventAccess": "READ"
    }
  }
}